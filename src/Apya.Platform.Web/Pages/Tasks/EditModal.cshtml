@page
@using Apya.Platform.Web.Pages.Tasks
@using Apya.Platform.Tasks
@using Volo.Abp.AspNetCore.Mvc.UI.Bootstrap.TagHelpers.Modal
@model EditModalModel
@{
    Layout = null;
}

<form asp-page="/Tasks/EditModal" method="post" id="EditTaskForm_@Model.Id" data-check-form-on-close="false">
<abp-modal size="ExtraLarge">
    <abp-modal-header title="🚀 Görev Paneli: @Model.Task.Title"></abp-modal-header>

    <abp-modal-body class="p-0 bg-light">
        
        <!-- ZAMAN TAKİBİ (TIME TRACKING) BANNER -->
        <div class="d-flex justify-content-between align-items-center bg-white px-4 py-3 border-bottom shadow-sm">
            <div>
                <span class="badge bg-dark bg-opacity-10 text-dark border border-secondary rounded-pill px-3 py-2 fs-6">
                    <i class="fa fa-clock text-primary me-2"></i>Zaman Takibi (Kronometre)
                </span>
            </div>
            <div>
                <button type="button" class="btn btn-outline-danger rounded-pill fw-bold shadow-sm px-4 pulse-animation" id="BtnStopTimer" style="display:none; transition: all 0.3s;">
                    <i class="fa fa-stop-circle me-1"></i> <span id="TimerElapsed">00:00:00</span>
                </button>
                <button type="button" class="btn btn-success rounded-pill fw-bold shadow-sm px-4" id="BtnStartTimer" style="transition: all 0.3s;">
                    <i class="fa fa-play me-1"></i> Süreyi Başlat
                </button>
            </div>
        </div>

        <ul class="nav nav-tabs nav-justified px-3 pt-3 border-bottom-0 shadow-sm bg-white" id="taskTabs_@Model.Id" role="tablist">
            <li class="nav-item">
                <a class="nav-link active fw-bold text-primary" id="details-tab_@Model.Id" data-bs-toggle="tab" href="#details_@Model.Id" role="tab">
                    <i class="fa fa-info-circle me-1"></i> Genel Bilgiler
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link fw-bold text-dark" id="subtasks-tab_@Model.Id" data-bs-toggle="tab" href="#subtasks_@Model.Id" role="tab">
                    <i class="fa fa-check-square text-success me-1"></i> Alt Görevler
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link fw-bold text-dark" id="comments-tab_@Model.Id" data-bs-toggle="tab" href="#comments_@Model.Id" role="tab">
                    <i class="fa fa-comments text-warning me-1"></i> Yorumlar
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link fw-bold text-dark" id="files-tab_@Model.Id" data-bs-toggle="tab" href="#files_@Model.Id" role="tab">
                    <i class="fa fa-paperclip text-info me-1"></i> Dosyalar
                </a>
            </li>
        </ul>

        <div class="tab-content p-4 bg-white border-top" id="taskTabsContent_@Model.Id" style="min-height: 450px;">
            <div class="tab-pane fade show active" id="details_@Model.Id" role="tabpanel">
                    <abp-input asp-for="Id" type="hidden" class="task-id-input" />
                    <abp-input asp-for="Task.ProjectId" type="hidden" />

                    <div class="row">
                        <div class="col-md-8 border-end pe-4">
                            <abp-input asp-for="Task.Title" label="Görev Başlığı" class="form-control-lg fw-bold" />
                            <div class="mt-3">
                                <abp-input asp-for="Task.Description" type="textarea" label="Açıklama" rows="6" placeholder="Bu görevin detayları nelerdir?" />
                            </div>
                        </div>
                        <div class="col-md-4 ps-4">
                            <h6 class="text-muted fw-bold mb-3"><i class="fa fa-calendar-alt me-2"></i>Zaman Planı</h6>
                            <abp-input asp-for="Task.StartDate" type="date" label="Başlangıç" />
                            <abp-input asp-for="Task.DueDate" type="date" label="Bitiş (Deadline)" />

                            <h6 class="text-muted fw-bold mt-4 mb-3"><i class="fa fa-cog me-2"></i>Durum & Atama</h6>
                            <abp-select asp-for="Task.Priority" label="Öncelik" />
                            <abp-select asp-for="Task.Status" label="Durum" />
                            <abp-select asp-for="Task.AssigneeId" asp-items="Model.UserList" label="Sorumlu Kişi" />

                            <div class="form-check form-switch mt-4 bg-light p-2 rounded border shadow-sm">
                                <input class="form-check-input ms-1 mt-2" style="transform: scale(1.2);" type="checkbox" asp-for="Task.IsPrivate">
                                <label class="form-check-label fw-bold text-danger ms-2 mt-1" asp-for="Task.IsPrivate">
                                    <i class="fa fa-user-secret me-1"></i> Gizli Görev
                                </label>
                                <small class="d-block text-muted ms-2 mt-1 px-1" style="font-size: 0.8rem; line-height: 1.2;">Sadece siz ve sorumlu kişi görebilir. Admin dahil başkası profilinize girdiğinde göremez.</small>
                            </div>
                        </div>
                    </div>
            </div>

            <div class="tab-pane fade" id="subtasks_@Model.Id" role="tabpanel">
                <h5 class="fw-bold mb-3">Yapılacaklar (Checklist)</h5>
                <div class="input-group mb-4 shadow-sm">
                    <input type="text" id="NewSubTaskTitle" class="form-control form-control-lg" placeholder="Yeni alt görev yaz...">
                    <button class="btn btn-success px-4" type="button" id="BtnAddSubTask"><i class="fa fa-plus me-1"></i> Ekle</button>
                </div>

                <div class="list-group list-group-flush border rounded-3" id="SubTaskList">
                    @if (Model.SubTasks != null && Model.SubTasks.Any())
                    {
                    @foreach (var sub in Model.SubTasks)
                        {
                    <div class="list-group-item list-group-item-action d-flex justify-content-between align-items-center p-3">
                        <div>
                            @if(sub.Status == Apya.Platform.Tasks.TaskStatus.Done) { <i class="fa fa-check-circle text-success fs-5 me-2"></i> }
                                    else { <i class="fa fa-circle-o text-secondary fs-5 me-2"></i> }

                            <strong class="fs-5 @(sub.Status == Apya.Platform.Tasks.TaskStatus.Done ? "text-decoration-line-through text-muted" : "")">@sub.Title</strong>

                            <span class="badge bg-secondary ms-2">@sub.Status</span>
                            @if(!string.IsNullOrEmpty(sub.AssigneeName))
                                    {
                            <span class="badge bg-info text-dark ms-1"><i class="fa fa-user"></i> @sub.AssigneeName</span>
                                    }
                        </div>
                        <div class="btn-group shadow-sm" role="group">
                            <button type="button" class="btn btn-sm btn-light border edit-subtask-btn" data-id="@sub.Id" title="Düzenle"><i class="fa fa-edit text-primary"></i></button>
                            <button type="button" class="btn btn-sm btn-light border delete-subtask-btn" data-id="@sub.Id" title="Sil"><i class="fa fa-trash text-danger"></i></button>
                        </div>
                    </div>
                        }
                    }
                    else
                    {
                    <div class="text-center text-muted p-5 bg-light rounded-3" id="NoSubTasksPlaceholder">
                        <i class="fa fa-list-ul fa-3x mb-3 text-secondary"></i>
                        <p class="fs-5">Henüz alt görev yok.</p>
                    </div>
                    }
                </div>
            </div>

            <div class="tab-pane fade" id="comments_@Model.Id" role="tabpanel">
                <div class="input-group mb-4 shadow-sm">
                    <input type="text" id="NewCommentText" class="form-control form-control-lg" placeholder="Bir yorum yaz...">
                    <button class="btn btn-primary px-4" type="button" id="BtnAddComment"><i class="fa fa-paper-plane me-1"></i> Gönder</button>
                </div>
                <div class="list-group list-group-flush" id="CommentList">
                    @if (Model.Comments != null && Model.Comments.Any())
                    {
                    @foreach (var comment in Model.Comments)
                        {
                    <div class="list-group-item bg-light border-0 mb-2 rounded-3">
                        <div class="d-flex w-100 justify-content-between mb-2">
                            <h6 class="mb-1 fw-bold text-primary"><i class="fa fa-user-circle me-1"></i> @comment.AuthorName</h6>
                            <small class="text-muted"><i class="fa fa-clock me-1"></i> @comment.CreationTime.ToShortDateString() @comment.CreationTime.ToShortTimeString()</small>
                        </div>
                        <p class="mb-1 text-dark">@comment.Text</p>
                    </div>
                        }
                    }
                    else
                    {
                    <div class="text-center text-muted p-5">Henüz yorum yapılmamış.</div>
                    }
                </div>
            </div>

            <div class="tab-pane fade" id="files_@Model.Id" role="tabpanel">
                <div class="input-group mb-4 shadow-sm">
                    <input type="file" class="form-control form-control-lg" id="FileInput">
                    <button class="btn btn-outline-secondary px-4" type="button" id="BtnUploadFile"><i class="fa fa-upload me-1"></i> Yükle</button>
                </div>

                <ul class="list-group list-group-flush" id="FileList">
                    @if (Model.Attachments != null && Model.Attachments.Any())
                    {
                    @foreach (var file in Model.Attachments)
                        {
                    <li class="list-group-item d-flex justify-content-between align-items-center bg-light border-0 mb-2 rounded-3">
                        <div>
                            <i class="fa fa-file-alt text-info fs-4 me-3"></i>
                            <a href="@file.DownloadUrl" target="_blank" class="text-decoration-none fw-bold fs-6">@file.FileName</a>
                            <small class="text-muted ms-3">(@(file.FileSize / 1024) KB) - @file.UploaderName</small>
                        </div>
                        <span class="text-muted small">@file.CreationTime.ToShortDateString()</span>
                    </li>
                        }
                    }
                    else
                    {
                    <div class="text-center text-muted p-5 no-file-text">Henüz dosya yüklenmemiş.</div>
                    }
                </ul>
            </div>
        </div>
    </abp-modal-body>
</abp-modal>
    <!-- Footer kaldırıldı (Auto-save) -->
</form>

<script>
    $('#BtnAddSubTask').click(function () {
        var title = $('#NewSubTaskTitle').val();
        var parentId = $('.task-id-input').val();
        if (!title) return;

        $.ajax({
            type: 'POST',
            url: '/Tasks/EditModal?handler=AddSubTask',
            headers: { 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() },
            data: { parentId: parentId, subTaskTitle: title },
            success: function (result) {
                abp.notify.success('Alt görev eklendi!');
                $('#NoSubTasksPlaceholder').remove();
                
                var newRowHtml = 
                    '<div class="list-group-item list-group-item-action d-flex justify-content-between align-items-center p-3 bg-light border-warning">' +
                        '<div>' +
                            '<i class="fa fa-circle-o text-secondary fs-5 me-2"></i>' +
                            '<strong class="fs-5">' + title + '</strong>' +
                            '<span class="badge bg-warning ms-2 text-dark">Yeni</span>' +
                        '</div>' +
                        '<div class="btn-group shadow-sm" role="group">' +
                            '<button type="button" class="btn btn-sm btn-light border" disabled title="Değiştirmek için sayfayı yenileyin"><i class="fa fa-edit text-primary"></i></button>' +
                            '<button type="button" class="btn btn-sm btn-light border" disabled title="Silmek için sayfayı yenileyin"><i class="fa fa-trash text-danger"></i></button>' +
                        '</div>' +
                    '</div>';
                $('#SubTaskList').prepend(newRowHtml);
                $('#NewSubTaskTitle').val('');
            },
            error: function (xhr) {
                abp.notify.error('Alt görev eklenemedi!');
                console.error("Alt görev ekleme hatası", xhr);
            }
        });
    });

    $(document).off('click', '.edit-subtask-btn').on('click', '.edit-subtask-btn', function () {
        var subTaskId = $(this).data('id');
        var subTaskModal = new abp.ModalManager({ viewUrl: abp.appPath + 'Tasks/EditModal' });
        subTaskModal.open({ id: subTaskId });
    });

    $(document).off('click', '.delete-subtask-btn').on('click', '.delete-subtask-btn', function () {
        var subTaskId = $(this).data('id');
        var $li = $(this).closest('.list-group-item');
        
        Swal.fire({
            title: 'Alt Görev Silinecek!',
            text: 'Bu alt görevi kalıcı olarak silmek üzeresiniz. Onaylamak için aşağıdaki alana "SİL" yazmalısınız.',
            icon: 'warning',
            input: 'text',
            inputPlaceholder: 'SİL',
            showCancelButton: true,
            confirmButtonText: '<i class="fa fa-trash"></i> Evet, Sil!',
            cancelButtonText: 'İptal',
            confirmButtonColor: '#dc3545',
            preConfirm: function (inputValue) {
                if (inputValue !== 'SİL') {
                    Swal.showValidationMessage('Silme işlemini onaylamak için tam olarak "SİL" yazmalısınız.');
                }
                return inputValue;
            }
        }).then(function (result) {
            if (result.isConfirmed) {
                apya.platform.tasks.task.delete(subTaskId).then(function () {
                    abp.notify.info('Başarıyla silindi.');
                    $li.remove();
                });
            }
        });
    });

    $('#BtnAddComment').click(function () {
        var text = $('#NewCommentText').val();
        var taskId = $('.task-id-input').val();
        if (!text) return;
        
        $.ajax({
            type: 'POST',
            url: '/Tasks/EditModal?handler=AddComment',
            headers: { 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() },
            data: { taskId: taskId, commentText: text },
            success: function (result) {
                abp.notify.success('Yorum gönderildi!');
                var now = new Date().toLocaleString();
                var newCommentHtml = '<div class="list-group-item bg-light border-success mb-2 rounded-3">' +
                    '<div class="d-flex w-100 justify-content-between mb-2">' +
                        '<h6 class="mb-1 fw-bold text-success">Siz (Az önce)</h6>' +
                        '<small class="text-muted">' + now + '</small>' +
                    '</div>' +
                    '<p class="mb-1">' + text + '</p>' +
                '</div>';
                $('#CommentList').prepend(newCommentHtml);
                $('#NewCommentText').val('');
            },
            error: function (xhr) {
                abp.notify.error('Yorum gönderilemedi!');
                console.error("Yorum gönderme hatası", xhr);
            }
        });
    });

    $('#BtnUploadFile').click(function () {
        var fileInput = document.getElementById('FileInput');
        var file = fileInput.files[0];
        var taskId = $('.task-id-input').val();
        if (!file) { abp.notify.warn('Lütfen bir dosya seçin.'); return; }

        var formData = new FormData();
        formData.append('file', file);

        $.ajax({
            url: '/api/tasks/attachments/upload/' + taskId,
            type: 'POST',
            data: formData,
            processData: false,
            contentType: false,
            headers: { 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() },
            success: function (result) {
                if (result.success) {
                    abp.notify.success('Dosya yüklendi!');
                    $('.no-file-text').remove();
                    $('#FileList').prepend('<li class="list-group-item d-flex justify-content-between align-items-center bg-light border-info mb-2 rounded-3"><div><i class="fa fa-file-alt text-info fs-4 me-3"></i><a href="/file/get/' + result.storedFileName + '" target="_blank" class="text-decoration-none fw-bold fs-6">' + file.name + '</a><small class="text-muted ms-3">Şimdi yüklendi</small></div><span class="badge bg-success">Yeni</span></li>');
                    fileInput.value = '';
                } else {
                    abp.notify.error('Dosya yüklenirken hata oluştu: ' + result.error);
                }
            },
            error: function (xhr) { 
                var msg = 'Dosya yüklenirken hata oluştu.';
                if (xhr.responseJSON && xhr.responseJSON.error) {
                    msg = xhr.responseJSON.error;
                }
                abp.notify.error(msg);
            }
        });
    });

    // --- ZAMAN TAKİBİ (TIME TRACKING) JS ---
    var timerInterval = null;
    var startTime = null;

    function refreshTimerState() {
        var taskId = $('.task-id-input').val();
        if(!taskId || taskId === '00000000-0000-0000-0000-000000000000') return;

        apya.platform.tasks.task.getActiveTimeLog().then(function(log) {
            if (log && log.taskId === taskId) {
                // Bu görev için sayaç çalışıyor
                startTime = new Date(log.startTime);
                $('#BtnStartTimer').hide();
                $('#BtnStopTimer').show();
                if (!timerInterval) {
                    timerInterval = setInterval(updateTimerDisplay, 1000);
                    updateTimerDisplay(); // ilk saniyeyi bekleme
                }
            } else if (log && log.taskId !== taskId) {
                // Başka görev için sayaç var, bunu kitleyelim
                $('#BtnStartTimer').prop('disabled', true).html('<i class="fa fa-lock me-1"></i> Başka Görevde Çalışıyor');
                $('#BtnStopTimer').hide();
            } else {
                // Sayaç çalışmıyor
                $('#BtnStartTimer').show().prop('disabled', false).html('<i class="fa fa-play me-1"></i> Süreyi Başlat');
                $('#BtnStopTimer').hide();
                if(timerInterval) {
                    clearInterval(timerInterval);
                    timerInterval = null;
                }
            }
        });
    }

    function updateTimerDisplay() {
        if (!startTime) return;
        var now = new Date();
        var diff = Math.floor((now - startTime) / 1000); // saniye
        var h = Math.floor(diff / 3600).toString().padStart(2, '0');
        var m = Math.floor((diff % 3600) / 60).toString().padStart(2, '0');
        var s = (diff % 60).toString().padStart(2, '0');
        $('#TimerElapsed').text(h + ":" + m + ":" + s);
    }

    $('#BtnStartTimer').click(function() {
        var taskId = $('.task-id-input').val();
        // UI olarak hemen feedback ver (optimistik)
        var originalBtnHtml = $(this).html();
        $(this).html('<i class="fa fa-spinner fa-spin me-1"></i> Başlatılıyor...').prop('disabled', true);

        apya.platform.tasks.task.startTimeTracking(taskId).then(function() {
            abp.notify.success('Zaman takibi başlatıldı!');
            refreshTimerState();
        }).catch(function(err) {
            $('#BtnStartTimer').html(originalBtnHtml).prop('disabled', false); // rollback
            abp.message.error(err.message || 'Zaman kaydı başlatılamadı, başka bir aktif sayaç olabilir.', 'Hata');
        });
    });

    $('#BtnStopTimer').click(function() {
        var taskId = $('.task-id-input').val();
        var originalBtnHtml = $(this).html();
        $(this).html('<i class="fa fa-spinner fa-spin me-1"></i> Kaydediliyor...').prop('disabled', true);

        apya.platform.tasks.task.stopTimeTracking(taskId).then(function() {
            abp.notify.success('Kronometre durduruldu ve sisteme kaydedildi!');
            refreshTimerState();
        }).catch(function() {
             $(this).html(originalBtnHtml).prop('disabled', false); // rollback
        });
    });

    // INIT
    setTimeout(refreshTimerState, 300);

    // === OTOMATİK KAYIT (AUTO-SAVE) MANTIĞI ===
    if (typeof window.taskAutoSaveTimeouts === 'undefined') {
        window.taskAutoSaveTimeouts = {};
    }
    
    $('#EditTaskForm_@Model.Id').on('input change', 'input:not(#NewSubTaskTitle, #NewCommentText, #FileInput), select, textarea', function() {
        if ($(this).hasClass('task-id-input')) return;
        
        var modalId = '@Model.Id';
        clearTimeout(window.taskAutoSaveTimeouts[modalId]);
        
        // Formda değişiklik olunca 1 sn sonra POST atar.
        window.taskAutoSaveTimeouts[modalId] = setTimeout(function() {
            var $form = $('#EditTaskForm_' + modalId);
            
            // Eğer form client-side validasyona takılıyorsa (zorunlu alanlar boşsa) POST atma.
            // Bu, "Description field is required" gibi sunucu hatalarını önler.
            if ($form.length && typeof $form.valid === 'function' && !$form.valid()) {
                console.log('Form henüz geçerli değil, kayıt ertelendi.');
                return;
            }

            var formData = $form.serialize();
            
            var $modal = $form.closest('.modal-content');
            var $titleContainer = $modal.find('.modal-title');
            
            var $status = $('#AutoSaveStatus_' + modalId.replace(/-/g, ''));
            if (!$status.length) {
                $titleContainer.append(' <small class="text-muted ms-2" id="AutoSaveStatus_' + modalId.replace(/-/g, '') + '" style="font-size: 0.75rem;"></small>');
                $status = $('#AutoSaveStatus_' + modalId.replace(/-/g, ''));
            }
            
            $status.html('<i class="fa fa-sync-alt fa-spin me-1"></i> Kaydediliyor...').show();

            abp.ajax({
                type: 'POST',
                url: '/Tasks/EditModal?Id=' + modalId,
                data: formData,
                headers: { 'RequestVerificationToken': $form.find('input[name="__RequestVerificationToken"]').val() }
            }).done(function () {
                $status.html('<i class="fa fa-check-circle text-success me-1"></i> Kaydedildi').show();
                setTimeout(function() { $status.fadeOut(500); }, 3000);
                abp.event.trigger('app.task.updated');
            }).fail(function (err) {
                $status.html('<i class="fa fa-exclamation-triangle text-danger me-1"></i> Kayıt Başarısız').show();
                if (err && err.message) {
                    abp.notify.error(err.message);
                } else if (err && err.responseText) {
                    abp.notify.error(err.responseText);
                }
            });
        }, 1000);
    });

    // Modal dışındayken değişiklikleri ebeveyn tablosuna yansıtmak istenir ise:
    $('#EditTaskForm_@Model.Id').closest('.modal').on('hidden.bs.modal', function () {
        // Eğer dış dünyada bir abp veritabanı gridi varsa onu tazeleyelim
        if (typeof window.dataTable !== 'undefined') {
            window.dataTable.ajax.reload(null, false);
        } else if (typeof window.projectsTable !== 'undefined') {
            window.projectsTable.ajax.reload(null, false);
        } else if (typeof window.tasksTable !== 'undefined') {
            window.tasksTable.ajax.reload(null, false);
        }
    });
</script>

<style>
    @Html.Raw("@keyframes pulse-border { 0% { box-shadow: 0 0 0 0 rgba(220, 53, 69, 0.7); } 70% { box-shadow: 0 0 0 10px rgba(220, 53, 69, 0); } 100% { box-shadow: 0 0 0 0 rgba(220, 53, 69, 0); } }")
    .pulse-animation {
      animation: pulse-border 2s infinite;
    }
</style>