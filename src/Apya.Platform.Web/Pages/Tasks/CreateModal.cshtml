@page
@using Volo.Abp.AspNetCore.Mvc.UI.Bootstrap.TagHelpers.Modal
@model Apya.Platform.Web.Pages.Tasks.CreateModalModel
@{
    Layout = null;
}

<form asp-page="/Tasks/CreateModal" method="post">
    <abp-modal size="Large">
        <abp-modal-header title="🚀 Yeni Görev Oluştur"></abp-modal-header>

        <abp-modal-body class="p-4">
            <input type="hidden" asp-for="Task.ProjectId" />

            <div class="alert alert-light border shadow-sm mb-4 d-flex align-items-center rounded-3" role="alert">
                <i class="fa fa-info-circle text-primary fs-3 me-3"></i>
                <div class="text-muted" style="font-size: 0.95rem;">
                    Görevinizin temel bilgilerini buradan hızlıca oluşturabilirsiniz. <strong>Dosya ekleme, alt görevler (checklist) ve yorumlaşma</strong> gibi detaylı işlemleri, görev oluştuktan sonra "Görev Detayı" ekranından yapabileceksiniz.
                </div>
            </div>

            <h6 class="text-primary fw-bold mb-3"><i class="fa fa-align-left me-2"></i>Temel Bilgiler</h6>
            <div class="bg-light p-3 rounded-3 border mb-4">
                <abp-input asp-for="Task.Title" label="Görev Başlığı" placeholder="Örn: Veritabanı optimizasyonu yapılacak..." />

                <div class="mt-3">
                    <abp-input asp-for="Task.Description" type="textarea" label="Açıklama" rows="3" placeholder="Görev ile ilgili genel bir özet veya not yazın..." />
                </div>
            </div>

            <h6 class="text-primary fw-bold mb-3"><i class="fa fa-calendar-alt me-2"></i>Zaman ve Planlama</h6>
            <div class="bg-light p-3 rounded-3 border mb-4">
                <div class="row g-3">
                    <div class="col-md-6">
                        <abp-input asp-for="Task.StartDate" label="Başlangıç Tarihi" type="date" />
                    </div>
                    <div class="col-md-6">
                        <abp-input asp-for="Task.DueDate" label="Bitiş Tarihi" type="date" />
                    </div>
                </div>
            </div>

            <h6 class="text-primary fw-bold mb-3"><i class="fa fa-user-tag me-2"></i>Durum ve Öncelik</h6>
            <div class="bg-light p-3 rounded-3 border">
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label fw-semibold text-dark" asp-for="Task.Status">Durum</label>
                        <select class="form-select shadow-sm" asp-for="Task.Status">
                            <option value="0">⏳ Bekliyor</option>
                            <option value="1">🏃 Devam Ediyor</option>
                            <option value="2">✅ Tamamlandı</option>
                        </select>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-semibold text-dark" asp-for="Task.Priority">Öncelik</label>
                        <select class="form-select shadow-sm" asp-for="Task.Priority">
                            <option value="0">🟢 Düşük</option>
                            <option value="1" selected>🟡 Normal</option>
                            <option value="2">🔴 Yüksek</option>
                        </select>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-semibold text-dark" asp-for="Task.AssigneeId">Atanan Kişi</label>
                        <select class="form-select shadow-sm" asp-for="Task.AssigneeId" asp-items="@Model.UserList">
                            <option value="">👤 -- Atanmadı --</option>
                        </select>
                    </div>
                </div>
            </div>

            <div class="mt-4 text-end">
                <div class="form-check form-switch d-inline-block text-start bg-light p-3 rounded border shadow-sm">
                    <input class="form-check-input ms-0 mt-1" style="transform: scale(1.3);" type="checkbox" asp-for="Task.IsPrivate">
                    <label class="form-check-label fw-bold text-danger ms-3" asp-for="Task.IsPrivate">
                        <i class="fa fa-user-secret me-1"></i> Bu görevi Gizli (Private) işaretle
                    </label>
                    <small class="d-block text-muted ms-3 mt-1">Gizli görevler, profilinize başkası (Admin vb.) girdiğinde görünmez.</small>
                </div>
            </div>

        </abp-modal-body>

        <abp-modal-footer buttons="@(AbpModalButtons.Cancel | AbpModalButtons.Save)"></abp-modal-footer>
    </abp-modal>
</form>