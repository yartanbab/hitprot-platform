@page
@using Microsoft.AspNetCore.Authorization
@using Apya.Platform.Permissions
@inject IAuthorizationService AuthorizationService
@using Apya.Platform.Web.Pages.Tasks
@model IndexModel
@section scripts
{
    <abp-script src="/Pages/Tasks/index.js" />
}

<div class="accordion mb-4" id="taskFiltersAccordion">
    <div class="accordion-item shadow-sm border-0 rounded-4">
        <h2 class="accordion-header" id="headingFilters">
            <button class="accordion-button collapsed fw-bold text-primary rounded-4" type="button" data-bs-toggle="collapse" data-bs-toggle="collapse" data-bs-target="#collapseFilters" aria-expanded="false" aria-controls="collapseFilters">
                <i class="fa fa-filter me-2"></i> Gelişmiş Filtreleme Seçenekleri
            </button>
        </h2>
        <div id="collapseFilters" class="accordion-collapse collapse" aria-labelledby="headingFilters" data-bs-parent="#taskFiltersAccordion">
            <div class="accordion-body bg-light rounded-bottom-4">
                <form id="TaskFilterForm" class="row g-3">
                    <div class="col-md-3">
                        <label for="Filter_TenantId" class="form-label fw-bold small text-muted">Müşteri Seçimi</label>
                        <select id="Filter_TenantId" class="form-select border-0 shadow-sm">
                            <option value="">Tümü</option>
                            <!-- TODO: Müşteri listesi eklenebilir -->
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label for="Filter_AssigneeId" class="form-label fw-bold small text-muted">Sorumlu Kişi</label>
                        <select id="Filter_AssigneeId" class="form-select border-0 shadow-sm">
                            <option value="">Herkes</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label for="Filter_Status" class="form-label fw-bold small text-muted">Durum</label>
                        <select id="Filter_Status" class="form-select border-0 shadow-sm">
                            <option value="">Tümü</option>
                            <option value="0">Bekliyor</option>
                            <option value="1">Sürüyor</option>
                            <option value="2">Testte</option>
                            <option value="3">Tamamlandı</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label for="Filter_MinDueDate" class="form-label fw-bold small text-muted">Başlangıç (Bitiş Trh)</label>
                        <input type="date" id="Filter_MinDueDate" class="form-control border-0 shadow-sm">
                    </div>
                    <div class="col-md-2">
                        <label for="Filter_MaxDueDate" class="form-label fw-bold small text-muted">Bitiş (Bitiş Trh)</label>
                        <input type="date" id="Filter_MaxDueDate" class="form-control border-0 shadow-sm">
                    </div>
                    <div class="col-12 text-end mt-3">
                        <button type="button" id="btn-clear-filters" class="btn btn-light shadow-sm me-2 fw-bold">Temizle</button>
                        <button type="button" id="btn-apply-filters" class="btn btn-primary shadow-sm fw-bold">
                            <i class="fa fa-search me-1"></i> Filtrele
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<abp-card>
    <abp-card-header>
        <abp-row>
            <abp-column size-md="_6">
                <abp-card-title>Görev Yönetimi</abp-card-title>
            </abp-column>
            <abp-column size-md="_6" class="text-end">
                @if (await AuthorizationService.IsGrantedAsync(PlatformPermissions.Tasks.Create))
                {
                    <abp-button id="NewTaskButton"
                                text="Yeni Görev Ekle"
                                icon="plus"
                                button-type="Primary" />
                }
            </abp-column>
        </abp-row>
    </abp-card-header>
    <abp-card-body>
        <abp-table striped-rows="true" id="TasksTable"></abp-table>
    </abp-card-body>
</abp-card>