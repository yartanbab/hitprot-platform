@page
@using Microsoft.AspNetCore.Authorization
@using Apya.Platform.Permissions
@inject IAuthorizationService AuthorizationService
@using Apya.Platform.Web.Pages.Tasks
@model IndexModel


@* ─── Gelişmiş Filtreleme Paneli ─── *@
<div class="accordion mb-3" id="taskFiltersAccordion">
    <div class="accordion-item shadow-sm border-0" style="border-radius:0.75rem;">
        <h2 class="accordion-header" id="headingFilters">
            <button class="accordion-button collapsed fw-bold text-primary"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#collapseFilters"
                    aria-expanded="false"
                    aria-controls="collapseFilters"
                    style="border-radius:0.75rem;">
                <i class="fa fa-filter me-2"></i> Gelişmiş Filtreleme Seçenekleri
            </button>
        </h2>
        <div id="collapseFilters"
             class="accordion-collapse collapse"
             aria-labelledby="headingFilters"
             data-bs-parent="#taskFiltersAccordion">
            <div class="accordion-body bg-light" style="border-radius:0 0 0.75rem 0.75rem;">
                <form id="TaskFilterForm" class="row g-3">
                    <div class="col-md-3">
                        <label for="Filter_AssigneeId" class="form-label fw-bold small text-muted">Sorumlu Kişi</label>
                        <select id="Filter_AssigneeId" class="form-select border-0 shadow-sm">
                            <option value="">Herkes</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label for="Filter_Status" class="form-label fw-bold small text-muted">Durum</label>
                        <select id="Filter_Status" class="form-select border-0 shadow-sm">
                            <option value="">Tümü</option>
                            <option value="1">Bekliyor</option>
                            <option value="2">Sürüyor</option>
                            <option value="3">Testte</option>
                            <option value="4">Tamamlandı</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label for="Filter_MinDueDate" class="form-label fw-bold small text-muted">Bitiş Tarihi (Başlangıç)</label>
                        <input type="date" id="Filter_MinDueDate" class="form-control border-0 shadow-sm">
                    </div>
                    <div class="col-md-2">
                        <label for="Filter_MaxDueDate" class="form-label fw-bold small text-muted">Bitiş Tarihi (Son)</label>
                        <input type="date" id="Filter_MaxDueDate" class="form-control border-0 shadow-sm">
                    </div>
                    <div class="col-md-3 d-flex align-items-end gap-2">
                        <button type="button" id="btn-apply-filters" class="btn btn-primary shadow-sm fw-bold flex-fill">
                            <i class="fa fa-search me-1"></i> Filtrele
                        </button>
                        <button type="button" id="btn-clear-filters" class="btn btn-light shadow-sm fw-bold flex-fill">Temizle</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@* ─── Görev Yönetimi ─── *@
<abp-card>
    <abp-card-header class="border-bottom-0 pb-0">
        <abp-row>
            <abp-column size-md="_6">
                <abp-card-title>Görev Panosu</abp-card-title>
            </abp-column>
            <abp-column size-md="_6" class="text-end">
                <div class="btn-group me-2" role="group">
                    <button type="button" id="btn-view-list" class="btn btn-outline-primary active">
                        <i class="fa fa-list me-1"></i> Liste
                    </button>
                    <button type="button" id="btn-view-kanban" class="btn btn-outline-primary">
                        <i class="fa fa-columns me-1"></i> Kanban
                    </button>
                    <button type="button" id="btn-view-gantt" class="btn btn-outline-primary">
                        <i class="fa fa-stream me-1"></i> Gantt
                    </button>
                </div>
                @if (await AuthorizationService.IsGrantedAsync(PlatformPermissions.Tasks.Create))
                {
                    <abp-button id="NewTaskButton"
                                text="Yeni Görev"
                                icon="plus"
                                button-type="Primary" />
                }
            </abp-column>
        </abp-row>
    </abp-card-header>
    <abp-card-body>
        @* --- LİSTE GÖRÜNÜMÜ --- *@
        <div id="view-list" class="view-panel">
            <abp-table striped-rows="true" id="TasksTable"></abp-table>
        </div>

        @* --- KANBAN GÖRÜNÜMÜ --- *@
        <div id="view-kanban" class="view-panel d-none">
            <div id="kanban-container" class="row gx-3 py-2 scroll-x" style="overflow-x: auto; flex-wrap: nowrap; min-height: 600px;">
                @* Todo Column *@
                <div class="col-kanban p-2" data-status="1">
                    <div class="kanban-header p-2 bg-light border rounded-top shadow-sm d-flex justify-content-between align-items-center">
                        <span class="fw-bold"><i class="fa fa-clock me-1 text-secondary"></i> Bekliyor</span>
                        <span class="badge bg-secondary rounded-pill" id="count-todo">0</span>
                    </div>
                    <div class="kanban-items p-2 bg-white border border-top-0 rounded-bottom shadow-sm" style="min-height: 500px;" id="kanban-todo"></div>
                </div>

                @* In Progress Column *@
                <div class="col-kanban p-2" data-status="2">
                    <div class="kanban-header p-2 bg-light border rounded-top shadow-sm d-flex justify-content-between align-items-center border-primary border-opacity-25" style="border-top: 3px solid #007bff !important;">
                        <span class="fw-bold text-primary"><i class="fa fa-spinner fa-spin me-1"></i> Sürüyor</span>
                        <span class="badge bg-primary rounded-pill" id="count-inprogress">0</span>
                    </div>
                    <div class="kanban-items p-2 bg-white border border-top-0 rounded-bottom shadow-sm" style="min-height: 500px;" id="kanban-inprogress"></div>
                </div>

                @* Test Column *@
                <div class="col-kanban p-2" data-status="3">
                    <div class="kanban-header p-2 bg-light border rounded-top shadow-sm d-flex justify-content-between align-items-center border-warning border-opacity-25" style="border-top: 3px solid #ffc107 !important;">
                        <span class="fw-bold text-warning"><i class="fa fa-flask me-1"></i> Testte</span>
                        <span class="badge bg-warning rounded-pill" id="count-test">0</span>
                    </div>
                    <div class="kanban-items p-2 bg-white border border-top-0 rounded-bottom shadow-sm" style="min-height: 500px;" id="kanban-test"></div>
                </div>

                @* Done Column *@
                <div class="col-kanban p-2" data-status="4">
                    <div class="kanban-header p-2 bg-light border rounded-top shadow-sm d-flex justify-content-between align-items-center border-success border-opacity-25" style="border-top: 3px solid #28a745 !important;">
                        <span class="fw-bold text-success"><i class="fa fa-check-circle me-1"></i> Tamamlandı</span>
                        <span class="badge bg-success rounded-pill" id="count-done">0</span>
                    </div>
                    <div class="kanban-items p-2 bg-white border border-top-0 rounded-bottom shadow-sm" style="min-height: 500px;" id="kanban-done"></div>
                </div>
            </div>
        </div>

        @* --- GANTT GÖRÜNÜMÜ --- *@
        <div id="view-gantt" class="view-panel d-none">
            <div class="gantt-controls mb-3 text-center">
                <div class="btn-group btn-group-sm">
                    <button type="button" class="btn btn-light border gantt-change-view" data-view="Day">Günlük</button>
                    <button type="button" class="btn btn-light border gantt-change-view" data-view="Week">Haftalık</button>
                    <button type="button" class="btn btn-light border gantt-change-view active" data-view="Month">Aylık</button>
                </div>
            </div>
            <div style="overflow-x: auto;">
                <svg id="gantt-svg"></svg>
            </div>
        </div>
    </abp-card-body>
</abp-card>

@section styles {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/frappe-gantt/0.6.1/frappe-gantt.min.css" />
    <style>
        /* Proje stili için Gantt özelleştirmesi */
        .gantt .bar-label { fill: #fff; font-weight: bold; }
        .gantt .bar-progress { fill: #007bff; }
        .gantt .bar { fill: #cbd5e0; }
        .gantt .priority-high .bar-progress { fill: #dc3545; }
        .gantt .priority-medium .bar-progress { fill: #ffc107; }
        .gantt .priority-low .bar-progress { fill: #28a745; }
    </style>
}

@section scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/frappe-gantt/0.6.1/frappe-gantt.min.js"></script>
    <abp-script src="/Pages/Tasks/index.js" />
}

<style>
    .col-kanban { width: 300px; flex: 0 0 300px; }
    .kanban-items { min-height: 200px; background-color: #fafafa !important; }
    .kanban-card { cursor: grab; transition: transform 0.2s, box-shadow 0.2s; border-radius: 0.5rem; border-left: 4px solid #dee2e6; }
    .kanban-card:hover { transform: translateY(-2px); box-shadow: 0 .5rem 1rem rgba(0,0,0,.15)!important; }
    .kanban-card.priority-high { border-left-color: #dc3545; }
    .kanban-card.priority-medium { border-left-color: #ffc107; }
    .kanban-card.priority-low { border-left-color: #28a745; }
    .kanban-placeholder { border: 2px dashed #ccc; background: #eee; height: 100px; border-radius: 0.5rem; margin-bottom: 0.5rem; }
    .scroll-x::-webkit-scrollbar { height: 8px; }
    .scroll-x::-webkit-scrollbar-thumb { background: #ccc; border-radius: 4px; }

    .timer-active { border-left-color: #dc3545 !important; background-color: #fff8f8 !important; box-shadow: 0 0 10px rgba(220, 53, 69, 0.2) !important; }
    .fa-beat { animation: fa-beat 1.5s infinite linear; }
    @@keyframes fa-beat {
        0% { transform: scale(1); }
        50% { transform: scale(1.2); }
        100% { transform: scale(1); }
    }
    @@keyframes heartbeat {
        0% { transform: scale(1); }
        50% { transform: scale(1.05); }
        100% { transform: scale(1); }
    }
    .heartbeat-animation { animation: heartbeat 1.5s infinite; }
</style>
