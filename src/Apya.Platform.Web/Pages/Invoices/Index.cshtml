@page
@model Apya.Platform.Web.Pages.Invoices.IndexModel
@using Apya.Platform.Invoices
@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<Apya.Platform.Localization.PlatformResource> L

<abp-card>
    <abp-card-header>
        <abp-row>
            <abp-column size-md="_6">
                <abp-card-title><i class="fa fa-file-invoice-dollar me-2"></i> Faturalar ve Ödemeler</abp-card-title>
            </abp-column>
            <abp-column size-md="_6" class="text-end">
                <abp-button id="NewInvoiceButton"
                            text="Yeni Fatura Oluştur"
                            icon="plus"
                            button-type="Primary" />
            </abp-column>
        </abp-row>
    </abp-card-header>
    <abp-card-body>
        <abp-table striped-rows="true" id="InvoicesTable"></abp-table>
    </abp-card-body>
</abp-card>

@section scripts {
    <abp-script src="/Pages/Invoices/index.js" />
}
