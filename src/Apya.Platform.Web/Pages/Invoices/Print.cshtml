@page "{id}"
@model Apya.Platform.Web.Pages.Invoices.PrintModel
@{
    Layout = null; // We use a clean layout for printing
    var inv = Model.InvoiceInfo;
    var subTotal = inv.Items.Sum(x => x.TotalPrice);
    var taxAmount = subTotal * (inv.TaxRate / 100);
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Fatura - @inv.InvoiceNumber</title>
    <!-- Use bootstrap for quick styling -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f8f9fa; -webkit-print-color-adjust: exact; }
        .invoice-box { max-width: 800px; margin: auto; padding: 30px; border: 1px solid #eee; box-shadow: 0 0 10px rgba(0, 0, 0, 0.15); background: white; }
        .invoice-header { display: flex; justify-content: space-between; border-bottom: 2px solid #000; padding-bottom: 20px; margin-bottom: 20px; }
        .brand h1 { margin: 0; color: #333; font-weight: 800; font-size: 32px; letter-spacing: -1px; }
        .brand p { margin: 0; color: #777; font-size: 14px; }
        .invoice-meta { text-align: right; }
        .meta-title { font-size: 24px; font-weight: bold; color: #555; text-transform: uppercase; letter-spacing: 2px; }
        .info-grid { display: flex; justify-content: space-between; margin-bottom: 30px; }
        .client-info h5 { font-weight: bold; color: #333; margin-bottom: 5px; text-transform: uppercase; font-size: 14px; }
        .client-info p { margin: 0; color: #555; font-size: 15px; }
        .table { margin-top: 20px; font-size: 15px; }
        .table th { background-color: #f8f9fa !important; border-bottom: 2px solid #dee2e6; color: #333; text-transform: uppercase; font-size: 13px; font-weight: 700; }
        .table-striped tbody tr:nth-of-type(odd) { background-color: #fafafa !important; }
        .totals-section { width: 300px; margin-left: auto; margin-top: 20px; }
        .totals-row { display: flex; justify-content: space-between; padding: 5px 0; border-bottom: 1px solid #eee; font-size: 15px; }
        .totals-row.grand-total { border-bottom: none; border-top: 2px solid #000; font-size: 20px; font-weight: bold; padding-top: 10px; color: #dc3545; }
        .status-stamp { display: inline-block; padding: 5px 15px; border-radius: 5px; font-weight: bold; font-size: 14px; margin-top: 10px; text-transform: uppercase; border: 2px solid; }
        .status-paid { color: #28a745; border-color: #28a745; background-color: rgba(40, 167, 69, 0.1); }
        .status-draft { color: #6c757d; border-color: #6c757d; background-color: rgba(108, 117, 125, 0.1); }
        .status-overdue { color: #dc3545; border-color: #dc3545; background-color: rgba(220, 53, 69, 0.1); }
        
        @@media print {
            body { background: white; }
            .invoice-box { box-shadow: none; border: none; padding: 0; }
            .btn-print { display: none !important; }
        }
    </style>
</head>
<body>
    <div class="container mt-5 mb-5">
        <div class="text-end mb-3">
            <button class="btn btn-secondary btn-print" onclick="window.print()">
                <i class="fa fa-print"></i> PDF İndir / Yazdır
            </button>
        </div>
        <div class="invoice-box">
            <div class="invoice-header">
                <div class="brand">
                    <h1>APYA PLATFORM</h1>
                    <p>Kurumsal Yönetim Çözümleri</p>
                    <p>VDK 1234567890</p>
                </div>
                <div class="invoice-meta">
                    <div class="meta-title">FATURA</div>
                    <div><strong>Tarih:</strong> @inv.InvoiceDate.ToString("dd.MM.yyyy")</div>
                    <div><strong>Fatura No:</strong> @inv.InvoiceNumber</div>
                    <div><strong>Vade:</strong> @inv.DueDate.ToString("dd.MM.yyyy")</div>
                    
                    @if (inv.Status == InvoiceStatus.Paid)
                    {
                        <div class="status-stamp status-paid">ÖDENDİ</div>
                    }
                    else if (inv.Status == InvoiceStatus.Overdue || (inv.DueDate < DateTime.Now && inv.Status != InvoiceStatus.Paid))
                    {
                        <div class="status-stamp status-overdue">GECİKMİŞ</div>
                    }
                    else
                    {
                        <div class="status-stamp status-draft">@inv.Status.ToString()</div>
                    }
                </div>
            </div>

            <div class="info-grid">
                <div class="client-info">
                    <h5>Sayın / Müşteri</h5>
                    <p><strong>Proje:</strong> @inv.ProjectName</p>
                    <p>Türkiye</p>
                </div>
            </div>

            <table class="table table-striped">
                <thead>
                    <tr>
                        <th class="text-start">Açıklama</th>
                        <th class="text-center">Miktar</th>
                        <th class="text-end">Birim Fiyat</th>
                        <th class="text-end">Tutar</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in inv.Items)
                    {
                        <tr>
                            <td class="text-start">@item.Description</td>
                            <td class="text-center">@item.Quantity.ToString("0.##")</td>
                            <td class="text-end">@item.UnitPrice.ToString("N2") @inv.Currency</td>
                            <td class="text-end">@item.TotalPrice.ToString("N2") @inv.Currency</td>
                        </tr>
                    }
                </tbody>
            </table>

            <div class="d-flex justify-content-end">
                <div class="totals-section">
                    <div class="totals-row">
                        <span>Ara Toplam:</span>
                        <span>@subTotal.ToString("N2") @inv.Currency</span>
                    </div>
                    <div class="totals-row">
                        <span>KDV (%@inv.TaxRate.ToString("0.##")):</span>
                        <span>@taxAmount.ToString("N2") @inv.Currency</span>
                    </div>
                    @if (inv.PaidAmount > 0)
                    {
                        <div class="totals-row text-success">
                            <span>Ödenen:</span>
                            <span>-@inv.PaidAmount.ToString("N2") @inv.Currency</span>
                        </div>
                    }
                    <div class="totals-row grand-total">
                        <span>TOPLAM:</span>
                        <span>@inv.Balance.ToString("N2") @inv.Currency</span>
                    </div>
                </div>
            </div>
            
            <div class="mt-5 text-muted small text-center" style="border-top: 1px solid #eee; padding-top: 15px;">
                Bu fatura bilgisayar ortamında üretilmiş olup, irsaliye yerine geçmez. <br />
                IBAN: TR00 0000 0000 0000 0000 0000 00
            </div>
        </div>
    </div>
</body>
</html>
