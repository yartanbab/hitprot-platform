@page
@model Apya.Platform.Web.Pages.Notifications.IndexModel
@{
    ViewData["Title"] = "Bildirimlerim";
}

<div class="container py-4">
    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
                    <h5 class="mb-0 fw-bold"><i class="fa fa-bell me-2 text-primary"></i> Bildirimlerim</h5>
                    <div class="d-flex gap-2">
                        <button id="btn-mark-all-page" class="btn btn-sm btn-outline-primary">
                            <i class="fa fa-check-double me-1"></i> Tümünü Okundu Yap
                        </button>
                    </div>
                </div>
                <div class="card-body p-0">
                    <div id="notifications-full-list" class="list-group list-group-flush">
                        @* Dinamik olarak doldurulacak *@
                        <div class="text-center p-5">
                            <div class="spinner-border text-primary" role="status"></div>
                            <p class="mt-2 text-muted">Bildirimler yükleniyor...</p>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-white text-center py-3">
                    <button id="load-more-btn" class="btn btn-sm btn-light d-none">
                        <i class="fa fa-chevron-down me-1"></i> Daha Fazla Göster
                    </button>
                    <p id="no-more-notif" class="text-muted text-sm d-none mb-0">Tüm bildirimler gösterildi.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .notif-page-item { transition: all 0.2s; border-left: 4px solid transparent; }
    .notif-page-item.unread { background-color: #fff9f0; border-left-color: #ffc107; font-weight: 500; }
    .notif-page-item:hover { background-color: #f8f9fa; }
</style>

@section scripts {
    <abp-script src="/Pages/Notifications/Index.js" />
}
