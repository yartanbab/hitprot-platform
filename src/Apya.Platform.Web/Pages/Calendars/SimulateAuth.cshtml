@page
@model Apya.Platform.Web.Pages.Calendars.SimulateAuthModel
@{
    Layout = null; 
}
<!DOCTYPE html>
<html>
<head>
    <title>Takvim Simülasyonu</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.min.css" />
    <style>
        body { background: #f4f7f6; height: 100vh; display: flex; align-items: center; justify-content: center; font-family: sans-serif; }
        .sim-card { background: #fff; padding: 40px; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); max-width: 450px; width: 100%; text-align: center; }
        .logo { width: 70px; margin-bottom: 20px; }
    </style>
</head>
<body>
    <div class="sim-card">
        @if (Request.Query["provider"] == "1")
        {
            <img src="https://upload.wikimedia.org/wikipedia/commons/a/a5/Google_Calendar_icon_%282020%29.svg" class="logo" />
            <h3>Google Giriş Simülasyonu</h3>
        }
        else
        {
            <img src="https://upload.wikimedia.org/wikipedia/commons/d/df/Microsoft_Office_Outlook_%282018%E2%80%93present%29.svg" class="logo" />
            <h3>Outlook Giriş Simülasyonu</h3>
        }
        <p class="text-muted mb-4 small">Lütfen bağlamak istediğiniz e-posta adresini girin.</p>
        
        <form id="SimForm">
            <input type="email" id="Email" class="form-control mb-3" placeholder="E-posta" required />
            <button type="submit" class="btn btn-primary w-100 py-2">Hesabı Bağla</button>
        </form>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="/libs/abp/aspnetcore-mvc-ui-theme-shared/bootstrap/utils/abp-utils.js"></script>
    <!-- We need the ABP JS proxies here to call the connect service -->
    <script src="/api/abp/api-definition"></script>
    <script>
        $('#SimForm').on('submit', function (e) {
            e.preventDefault();
            var email = $('#Email').val();
            var provider = parseInt(new URLSearchParams(window.location.search).get('provider'));
            
            // Call the real service
            fetch('/api/app/calendar/connect-account', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    provider: provider,
                    externalEmail: email,
                    accessToken: 'sim_at_' + Date.now(),
                    refreshToken: 'sim_rt_' + Date.now()
                })
            }).then(r => {
                if(r.ok) {
                    window.location.href = '/Calendars?msg=success';
                } else {
                    alert('Hata! Veritabanı bağlantısını kontrol edin.');
                }
            });
        });
    </script>
</body>
</html>
