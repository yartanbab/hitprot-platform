@page
@using Apya.Platform.Web.Pages.Projects
@using Volo.Abp.AspNetCore.Mvc.UI.Bootstrap.TagHelpers.Modal
@model CreateModalModel
@{
    Layout = null;
}

<form asp-page="/Projects/CreateModal" method="post" enctype="multipart/form-data">
    <abp-modal>
        <abp-modal-header title="Yeni Proje Oluştur"></abp-modal-header>

        <abp-modal-body>
            <abp-input asp-for="Project.Name" label="Proje Adı" />
            <abp-input asp-for="Project.Description" type="textarea" label="Açıklama" />

            <div class="mb-3">
                <label class="form-label">Proje Dosyası (Opsiyonel)</label>
                <input type="file" class="form-control" asp-for="UploadFile">
                <small class="text-muted">PDF, Excel veya Görsel yükleyebilirsiniz.</small>
            </div>

        </abp-modal-body>

        <abp-modal-footer buttons="@(AbpModalButtons.Cancel|AbpModalButtons.Save)"></abp-modal-footer>
    </abp-modal>
</form>