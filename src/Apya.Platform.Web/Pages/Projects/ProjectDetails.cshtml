@page "{id:Guid}"
@using Apya.Platform.Permissions
@using Microsoft.AspNetCore.Authorization
@using Volo.Abp.AspNetCore.Mvc.UI.Bootstrap.TagHelpers.Modal
@inject IAuthorizationService AuthorizationService
@model Apya.Platform.Web.Pages.Projects.ProjectDetailsModel
@{
    ViewBag.Title = Model.Project?.Name;

    var totalTasks     = Model.Tasks?.Count ?? 0;
    var completedTasks = Model.Tasks?.Count(t => (int)t.Status == 3) ?? 0;
    var progressPct    = totalTasks > 0 ? (int)Math.Round((double)completedTasks / totalTasks * 100) : 0;
    var assigneeCount  = Model.Tasks?.Where(t => t.AssigneeId.HasValue).Select(t => t.AssigneeId).Distinct().Count() ?? 0;
    var facepileCount  = Math.Min(assigneeCount, 5);
}

<style>
    .project-dashboard-card { border-radius: 1rem; border: none; background: linear-gradient(to right, #ffffff, #f8f9fa); }
    .avatar-group { display: flex; align-items: center; }
    .avatar-circle {
        width: 36px; height: 36px; border-radius: 50%;
        background-color: #4e73df; color: #fff;
        display: flex; align-items: center; justify-content: center;
        font-weight: bold; font-size: 0.85rem;
        border: 2px solid #fff; margin-left: -10px;
        box-shadow: 0 2px 6px rgba(0,0,0,0.15);
    }
    .avatar-circle:first-child { margin-left: 0; }
    .avatar-circle.more { background-color: #6c757d; }
    
    /* Kanban Styles */
    .kanban-board {
        display: flex;
        gap: 1.5rem;
        overflow-x: auto;
        padding-bottom: 1rem;
        min-height: 400px;
    }
    .kanban-column {
        flex: 0 0 300px;
        background: #f8f9fa;
        border-radius: 0.75rem;
        padding: 1rem;
        display: flex;
        flex-direction: column;
    }
    .kanban-header {
        font-weight: 700;
        font-size: 0.95rem;
        text-transform: uppercase;
        margin-bottom: 1rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        letter-spacing: 0.5px;
    }
    .kanban-cards {
        flex: 1;
        min-height: 100px;
    }
    .kanban-card {
        background: #fff;
        border-radius: 0.5rem;
        padding: 1rem;
        margin-bottom: 0.75rem;
        cursor: grab;
        border-left: 5px solid transparent;
        transition: transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.2s;
        border-top: 1px solid #eee;
        border-right: 1px solid #eee;
        border-bottom: 1px solid #eee;
    }
    .kanban-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 5px 15px rgba(0,0,0,0.08);
    }
    .kanban-card:active {
        cursor: grabbing;
    }
    .kanban-card[data-priority="1"] { border-left-color: #198754; } /* Low */
    .kanban-card[data-priority="2"] { border-left-color: #ffc107; } /* Medium */
    .kanban-card[data-priority="3"] { border-left-color: #fd7e14; } /* High */
    .kanban-card[data-priority="4"] { border-left-color: #dc3545; } /* Critical */
    
    .sortable-ghost { opacity: 0.4; }
</style>

@* ─── Dashboard Header Card ─── *@
<div class="card shadow-sm mb-4 project-dashboard-card">
    <div class="card-body p-4">
        <div class="row align-items-center">

            @* Proje Bilgileri *@
            @* Proje Bilgileri *@
            <div class="col-md-4">
                <span class="badge bg-primary bg-opacity-10 text-primary mb-2 rounded-pill px-3 py-2">
                    <i class="fa fa-tag me-1"></i> @Model.Project?.Code
                </span>
                <h1 class="display-6 fw-bold text-dark mb-2" style="font-size: 1.8rem;">
                    <i class="fa fa-rocket text-primary me-2"></i>@Model.Project?.Name
                </h1>
                <p class="text-muted mb-0" style="font-size: 0.95rem;">@Model.Project?.Description</p>
            </div>

            @* APYA AI Karar Motoru - Risk Skoru *@
            <div class="col-md-3 border-start px-4">
                <div class="d-flex align-items-center mb-2">
                    <div class="bg-@Model.AiRiskColor bg-opacity-10 p-2 rounded-circle me-3 border border-@Model.AiRiskColor shadow-sm d-flex align-items-center justify-content-center" style="width: 45px; height: 45px;">
                        <i class="fa fa-robot text-@Model.AiRiskColor fs-4"></i>
                    </div>
                    <div>
                        <h6 class="text-uppercase text-muted fw-bold mb-0" style="font-size:0.75rem;letter-spacing:1px;">AI Risk Öngörüsü</h6>
                        <span class="fw-bold fs-5 text-@Model.AiRiskColor">%@Model.AiRiskScore Risk</span>
                    </div>
                </div>
                <p class="text-muted small mb-0 lh-sm" style="font-size: 0.8rem; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
                    @Model.AiRiskMessage
                </p>
            </div>

            @* İlerleme *@
            <div class="col-md-2 border-start border-end px-3">
                <h6 class="text-uppercase text-muted fw-bold mb-3" style="font-size:0.75rem;letter-spacing:1px;">Proje İlerlemesi</h6>
                <div class="d-flex justify-content-between align-items-center mb-1">
                    <span class="fw-bold fs-5 @(progressPct == 100 ? "text-success" : "text-primary")">%@progressPct</span>
                </div>
                <div class="progress shadow-sm" style="height:8px;border-radius:4px;">
                    <div class="progress-bar @(progressPct == 100 ? "bg-success" : "bg-primary progress-bar-striped progress-bar-animated")"
                         role="progressbar"
                         style="width:@progressPct%"
                         aria-valuenow="@progressPct" aria-valuemin="0" aria-valuemax="100"></div>
                </div>
                <div class="text-muted small mt-1">@completedTasks / @totalTasks Görev Bitti</div>
            </div>

            @* Ekip & Geri Butonu *@
            <div class="col-md-3 ps-4 d-flex flex-column justify-content-center">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <a href="/Projects" class="btn btn-light border btn-sm shadow-sm rounded-pill fw-bold px-3 ms-auto">
                        <i class="fa fa-arrow-left me-1"></i> Geri Dön
                    </a>
                </div>
                <div>
                    <h6 class="text-uppercase text-muted fw-bold mb-2" style="font-size:0.75rem;letter-spacing:1px;">Ekip (@assigneeCount)</h6>
                    <div class="avatar-group">
                        @for (int i = 0; i < facepileCount; i++)
                        {
                            <div class="avatar-circle"><i class="fa fa-user"></i></div>
                        }
                        @if (assigneeCount > 5)
                        {
                            <div class="avatar-circle more">+@(assigneeCount - 5)</div>
                        }
                        @if (facepileCount == 0)
                        {
                            <span class="text-muted small">Henüz atanan yok</span>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@* ─── Görev Listesi (View Tabs) ─── *@
<abp-card class="shadow-sm rounded-4 border-0">
    <abp-card-header class="bg-white border-bottom-0 pt-4 pb-0">
        <abp-row class="align-items-center">
            <abp-column size="_6">
                <!-- Tabs -->
                <ul class="nav nav-tabs border-0" id="projectViewTabs" role="tablist">
                    <li class="nav-item border-0" role="presentation">
                        <button class="nav-link active fw-bold text-dark border-0 border-bottom border-primary border-3" id="list-tab" data-bs-toggle="tab" data-bs-target="#list-view" type="button" role="tab" aria-controls="list-view" aria-selected="true" style="background:transparent;">
                            <i class="fa fa-list me-2 text-primary"></i>Liste
                        </button>
                    </li>
                    <li class="nav-item border-0 ms-3" role="presentation">
                        <button class="nav-link fw-bold text-muted border-0" id="board-tab" data-bs-toggle="tab" data-bs-target="#board-view" type="button" role="tab" aria-controls="board-view" aria-selected="false" style="background:transparent;">
                            <i class="fa fa-columns me-2"></i>Kanban
                        </button>
                    </li>
                </ul>
            </abp-column>
            <abp-column size="_6" class="text-end">
                @if (await AuthorizationService.IsGrantedAsync(PlatformPermissions.Tasks.Create))
                {
                    <button id="btn-create-task"
                            class="btn btn-primary rounded-pill px-4 shadow-sm"
                            data-project-id="@Model.Id">
                        <i class="fa fa-plus me-1"></i> Yeni Görev Ekle
                    </button>
                }
            </abp-column>
        </abp-row>
    </abp-card-header>

    <abp-card-body class="pt-3">
        <div class="tab-content" id="projectViewTabsContent">
            
            @* --- LİSTE GÖRÜNÜMÜ --- *@
            <div class="tab-pane fade show active" id="list-view" role="tabpanel" aria-labelledby="list-tab">
                <div class="table-responsive mt-2">
                    <abp-table striped-rows="true" class="table-hover align-middle border" id="ProjectTasksTable"></abp-table>
                </div>
            </div>

            @* --- KANBAN BOARD GÖRÜNÜMÜ --- *@
            <div class="tab-pane fade" id="board-view" role="tabpanel" aria-labelledby="board-tab">
                <div class="kanban-board mt-2">
                    
                    <!-- Todo/Yapılacak Column -->
                    <div class="kanban-column shadow-sm border" data-status-id="1">
                        <div class="kanban-header">
                            <span class="text-secondary"><i class="fa fa-circle me-2"></i>Yapılacak</span>
                            <span class="badge bg-secondary rounded-pill kanban-count">0</span>
                        </div>
                        <div class="kanban-cards" id="kanban-todo"></div>
                    </div>

                    <!-- In Progress/Sürüyor Column -->
                    <div class="kanban-column shadow-sm border" data-status-id="2">
                        <div class="kanban-header">
                            <span class="text-warning text-dark"><i class="fa fa-circle me-2"></i>Sürüyor</span>
                            <span class="badge bg-warning text-dark rounded-pill kanban-count">0</span>
                        </div>
                        <div class="kanban-cards" id="kanban-inprogress"></div>
                    </div>

                    <!-- In Review/Testte Column -->
                    <div class="kanban-column shadow-sm border" data-status-id="3">
                        <div class="kanban-header">
                            <span class="text-info"><i class="fa fa-circle me-2"></i>Testte</span>
                            <span class="badge bg-info rounded-pill kanban-count">0</span>
                        </div>
                        <div class="kanban-cards" id="kanban-inreview"></div>
                    </div>

                    <!-- Done/Tamamlandı Column -->
                    <div class="kanban-column shadow-sm border" data-status-id="4">
                        <div class="kanban-header">
                            <span class="text-success"><i class="fa fa-check-circle me-2"></i>Tamamlandı</span>
                            <span class="badge bg-success rounded-pill kanban-count">0</span>
                        </div>
                        <div class="kanban-cards" id="kanban-done"></div>
                    </div>

                </div>
            </div>

        </div>
    </abp-card-body>
</abp-card>

@* ─── Danger Zone ─── *@
@if (await AuthorizationService.IsGrantedAsync("Platform.Projects.ManageTeam") || await AuthorizationService.IsGrantedAsync(PlatformPermissions.Projects.Delete))
{
    <div class="card mt-5 border-danger shadow-sm">
        <div class="card-header bg-danger text-white d-flex align-items-center">
            <i class="fa fa-exclamation-triangle fs-5 me-2"></i>
            <h5 class="mb-0 fw-bold" style="letter-spacing:1px;">TEHLİKELİ BÖLGE (DANGER ZONE)</h5>
        </div>
        <div class="card-body bg-light">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="fw-bold text-dark mb-1">Bu Projeyi Sil</h6>
                    <p class="text-muted mb-0 small">
                        Dikkat! Bir projeyi sildiğinizde projeye bağlı <strong>tüm görevler, alt görevler ve dosyalar kalıcı olarak silinir.</strong> Bu işlem geri alınamaz.
                    </p>
                </div>
                <div class="ms-4">
                    <button class="btn btn-outline-danger fw-bold shadow-sm"
                            id="btn-delete-project"
                            data-project-id="@Model.Id"
                            data-project-code="@Model.Project?.Code">
                        <i class="fa fa-trash me-2"></i>Projeyi Sil
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@section scripts {
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@latest/Sortable.min.js"></script>
    <abp-script src="/Pages/Projects/ProjectDetails.js" />
}