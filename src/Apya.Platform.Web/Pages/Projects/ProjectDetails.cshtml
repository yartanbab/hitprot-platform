@page "{id:Guid}"
@using Apya.Platform.Permissions
@using Microsoft.AspNetCore.Authorization
@using Volo.Abp.AspNetCore.Mvc.UI.Bootstrap.TagHelpers.Modal
@inject IAuthorizationService AuthorizationService
@model Apya.Platform.Web.Pages.ProjectDetailsModel
@{
    ViewBag.Title = Model.Project?.Name;
}

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <div class="row">
            <div class="col-md-8">
                <h1 class="display-6 text-primary">
                    <i class="fa fa-rocket me-2"></i> @Model.Project?.Name
                </h1>
                <p class="lead text-muted">@Model.Project?.Code</p>
                <p>@Model.Project?.Description</p>
            </div>
            <div class="col-md-4 text-end">
                <a href="/" class="btn btn-outline-secondary btn-sm">
                    <i class="fa fa-arrow-left"></i> Listeye Dön
                </a>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header bg-light d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="fa fa-tasks me-2"></i> Görevler</h5>

        @if (await AuthorizationService.IsGrantedAsync(PlatformPermissions.Tasks.Create))
        {
        <button id="btn-create-task"
                class="btn btn-primary btn-sm"
                data-project-id="@Model.Id">
            <i class="fa fa-plus"></i> Yeni Görev Ekle
        </button>
        }
    </div>
    <div class="card-body p-0">
        @if (Model.Tasks != null && Model.Tasks.Any())
        {
        <div class="list-group list-group-flush">
            @foreach (var task in Model.Tasks)
                {
            <div class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="mb-1 fw-bold">@task.Title</h6>
                    <small class="text-muted">@task.Description</small>
                </div>

                @if(task.Status == 0) { <span class="badge bg-secondary rounded-pill">Bekliyor</span> }
                        else if(task.Status == 1) { <span class="badge bg-warning text-dark rounded-pill">Sürüyor</span> }
                        else { <span class="badge bg-success rounded-pill">Tamamlandı</span> }
            </div>
                }
        </div>
        }
        else
        {
        <div class="p-5 text-center text-muted">
            <i class="fa fa-clipboard-list fa-3x mb-3 text-secondary"></i>
            <p>Henüz bu projeye ait görev bulunmuyor.</p>
        </div>
        }
    </div>
</div>

@section scripts {
    <script>
        $(function () {
            // Modal Tanımı
            var createTaskModal = new abp.ModalManager({
                viewUrl: abp.appPath + 'Tasks/CreateModal'
            });

            // Butona Tıklama Olayı
            $('#btn-create-task').click(function (e) {
                e.preventDefault();
                var projectId = $(this).attr('data-project-id');
                createTaskModal.open({ projectId: projectId });
            });

            // Kayıt Sonrası Yenileme
            createTaskModal.onResult(function () {
                abp.notify.success('Görev başarıyla eklendi!');
                window.location.reload();
            });
        });
    </script>
}