@page "{id:Guid}"
@using Apya.Platform.Permissions
@using Microsoft.AspNetCore.Authorization
@using Volo.Abp.AspNetCore.Mvc.UI.Bootstrap.TagHelpers.Modal
@inject IAuthorizationService AuthorizationService
@model Apya.Platform.Web.Pages.Projects.ProjectDetailsModel
@{
    ViewBag.Title = Model.Project?.Name;

    var totalTasks     = Model.Tasks?.Count ?? 0;
    var completedTasks = Model.Tasks?.Count(t => (int)t.Status == 3) ?? 0;
    var progressPct    = totalTasks > 0 ? (int)Math.Round((double)completedTasks / totalTasks * 100) : 0;
    var assigneeCount  = Model.Tasks?.Where(t => t.AssigneeId.HasValue).Select(t => t.AssigneeId).Distinct().Count() ?? 0;
    var facepileCount  = Math.Min(assigneeCount, 5);
}

<style>
    .project-dashboard-card { border-radius: 1rem; border: none; background: linear-gradient(to right, #ffffff, #f8f9fa); }
    .avatar-group { display: flex; align-items: center; }
    .avatar-circle {
        width: 36px; height: 36px; border-radius: 50%;
        background-color: #4e73df; color: #fff;
        display: flex; align-items: center; justify-content: center;
        font-weight: bold; font-size: 0.85rem;
        border: 2px solid #fff; margin-left: -10px;
        box-shadow: 0 2px 6px rgba(0,0,0,0.15);
    }
    .avatar-circle:first-child { margin-left: 0; }
    .avatar-circle.more { background-color: #6c757d; }
</style>

@* ─── Dashboard Header Card ─── *@
<div class="card shadow-sm mb-4 project-dashboard-card">
    <div class="card-body p-4">
        <div class="row align-items-center">

            @* Proje Bilgileri *@
            <div class="col-md-5">
                <span class="badge bg-primary bg-opacity-10 text-primary mb-2 rounded-pill px-3 py-2">
                    <i class="fa fa-tag me-1"></i> @Model.Project?.Code
                </span>
                <h1 class="display-6 fw-bold text-dark mb-2">
                    <i class="fa fa-rocket text-primary me-2"></i>@Model.Project?.Name
                </h1>
                <p class="text-muted mb-0" style="font-size: 1.05rem;">@Model.Project?.Description</p>
            </div>

            @* İlerleme *@
            <div class="col-md-3 border-start border-end px-4">
                <h6 class="text-uppercase text-muted fw-bold mb-3" style="font-size:0.78rem;letter-spacing:1px;">Proje İlerlemesi</h6>
                <div class="d-flex justify-content-between align-items-center mb-1">
                    <span class="fw-bold fs-5 @(progressPct == 100 ? "text-success" : "text-primary")">%@progressPct</span>
                    <span class="text-muted small">@completedTasks / @totalTasks Görev</span>
                </div>
                <div class="progress" style="height:10px;border-radius:5px;">
                    <div class="progress-bar @(progressPct == 100 ? "bg-success" : "bg-primary progress-bar-striped progress-bar-animated")"
                         role="progressbar"
                         style="width:@progressPct%"
                         aria-valuenow="@progressPct" aria-valuemin="0" aria-valuemax="100"></div>
                </div>
            </div>

            @* Ekip & Geri Butonu *@
            <div class="col-md-4 ps-4">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <h6 class="text-uppercase text-muted fw-bold mb-2" style="font-size:0.78rem;letter-spacing:1px;">Ekip Üyeleri</h6>
                        <div class="avatar-group">
                            @for (int i = 0; i < facepileCount; i++)
                            {
                                <div class="avatar-circle"><i class="fa fa-user"></i></div>
                            }
                            @if (assigneeCount > 5)
                            {
                                <div class="avatar-circle more">+@(assigneeCount - 5)</div>
                            }
                            @if (facepileCount == 0)
                            {
                                <span class="text-muted small">Henüz atanan yok</span>
                            }
                        </div>
                    </div>
                    <a href="/Projects" class="btn btn-light btn-sm shadow-sm rounded-pill fw-bold px-3 ms-3">
                        <i class="fa fa-arrow-left me-1"></i> Listeye Dön
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@* ─── Görev Listesi ─── *@
<abp-card class="shadow-sm rounded-4 border-0">
    <abp-card-header class="bg-white border-bottom-0 pt-4 pb-0">
        <abp-row>
            <abp-column size="_6">
                <abp-card-title class="fw-bold fs-5 text-dark">
                    <i class="fa fa-tasks text-primary me-2"></i>Görev Listesi
                </abp-card-title>
            </abp-column>
            <abp-column size="_6" class="text-end">
                @if (await AuthorizationService.IsGrantedAsync(PlatformPermissions.Tasks.Create))
                {
                    <button id="btn-create-task"
                            class="btn btn-primary rounded-pill px-4 shadow-sm"
                            data-project-id="@Model.Id">
                        <i class="fa fa-plus me-1"></i> Yeni Görev Ekle
                    </button>
                }
            </abp-column>
        </abp-row>
    </abp-card-header>

    <abp-card-body>
        <div class="table-responsive">
            <abp-table striped-rows="true" class="table-hover align-middle border" id="ProjectTasksTable"></abp-table>
        </div>
    </abp-card-body>
</abp-card>

@* ─── Danger Zone ─── *@
@if (await AuthorizationService.IsGrantedAsync("Platform.Projects.ManageTeam") || await AuthorizationService.IsGrantedAsync(PlatformPermissions.Projects.Delete))
{
    <div class="card mt-5 border-danger shadow-sm">
        <div class="card-header bg-danger text-white d-flex align-items-center">
            <i class="fa fa-exclamation-triangle fs-5 me-2"></i>
            <h5 class="mb-0 fw-bold" style="letter-spacing:1px;">TEHLİKELİ BÖLGE (DANGER ZONE)</h5>
        </div>
        <div class="card-body bg-light">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="fw-bold text-dark mb-1">Bu Projeyi Sil</h6>
                    <p class="text-muted mb-0 small">
                        Dikkat! Bir projeyi sildiğinizde projeye bağlı <strong>tüm görevler, alt görevler ve dosyalar kalıcı olarak silinir.</strong> Bu işlem geri alınamaz.
                    </p>
                </div>
                <div class="ms-4">
                    <button class="btn btn-outline-danger fw-bold shadow-sm"
                            id="btn-delete-project"
                            data-project-id="@Model.Id"
                            data-project-code="@Model.Project?.Code">
                        <i class="fa fa-trash me-2"></i>Projeyi Sil
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@section scripts {
    <abp-script src="/Pages/Projects/ProjectDetails.js" />
}